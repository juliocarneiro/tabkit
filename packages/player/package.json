{
  "name": "@tabkit/player",
  "version": "0.1.3",
  "description": "Playback engine with cursor sync and metronome for tabkit tablatures",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@tabkit/core": "^0.1.3"
  },
  "keywords": [
    "tablature",
    "player",
    "metronome",
    "cursor",
    "tabkit"
  ],
  "license": "MIT",
  "author": "Julio Carneiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/juliocarneiro/tabkit",
    "directory": "packages/player"
  },
  "homepage": "https://github.com/juliocarneiro/tabkit#readme",
  "bugs": {
    "url": "https://github.com/juliocarneiro/tabkit/issues"
  },
  "sideEffects": false
}
