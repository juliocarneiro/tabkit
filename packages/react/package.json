{
  "name": "@tabkit/react",
  "version": "0.1.1",
  "description": "React components and hooks for tabkit — TabSheet, TabPlayer, TabEditor",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17",
    "tabkit": "^0.1.0",
    "@tabkit/player": "^0.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "jsdom": "^28.1.0"
  },
  "keywords": [
    "tablature",
    "react",
    "component",
    "hooks",
    "svg",
    "tabkit"
  ],
  "license": "MIT",
  "author": "Julio Carneiro",
  "repository": {
    "type": "git",
    "url": "https://github.com/juliocarneiro/tabkit",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/juliocarneiro/tabkit#readme",
  "bugs": {
    "url": "https://github.com/juliocarneiro/tabkit/issues"
  },
  "sideEffects": false
}
